{
  "name": "@webhot/worker",
  "version": "0.1.0",
  "private": true,
  "description": "WebHot Background Worker",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@webhot/core": "workspace:*",
    "@webhot/adapters": "workspace:*",
    "@webhot/logging": "workspace:*",
    "@webhot/schemas": "workspace:*",
    "bullmq": "^5.0.0",
    "ioredis": "^5.4.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
