{
  "name": "@webhot/api",
  "version": "0.1.0",
  "private": true,
  "description": "WebHot Core API Server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@webhot/core": "workspace:*",
    "@webhot/logging": "workspace:*",
    "@webhot/schemas": "workspace:*",
    "fastify": "^5.2.0",
    "@fastify/cors": "^10.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
