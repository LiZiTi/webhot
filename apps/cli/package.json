{
  "name": "@webhot/cli",
  "version": "0.1.0",
  "private": true,
  "description": "WebHot CLI — 命令行热点查询工具",
  "type": "module",
  "bin": {
    "webhot": "src/index.ts"
  },
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@webhot/schemas": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
